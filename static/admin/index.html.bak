<!DOCTYPE html>
<html lang="ru" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Daber Dict — Admin</title>
<link rel="stylesheet" href="/static/design-system.css">
<style>
  .admin-body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    color: var(--color-ink);
    font-family: var(--font-body);
  }

  /* ── Header ── */
  .admin-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-rule);
    padding: 0 var(--space-xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .admin-header h1 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-ink);
  }
  .logout-btn {
    color: var(--color-muted);
    cursor: pointer;
    font-size: 0.8125rem;
    border: none;
    background: none;
    font-family: var(--font-body);
    transition: color 0.15s;
  }
  .logout-btn:hover { color: var(--color-red); }

  /* ── Tabs ── */
  .tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--color-rule);
    padding: 0 var(--space-xl);
    background: var(--color-paper);
  }
  .tab {
    padding: 12px var(--space-lg);
    border: none;
    background: none;
    color: var(--color-muted);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.875rem;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .tab:hover { color: var(--color-ink); }
  .tab.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .tab .count {
    background: var(--color-surface-2);
    border-radius: var(--radius-pill);
    padding: 1px 8px;
    font-size: 0.75rem;
    margin-left: 6px;
    font-weight: 500;
  }
  .tab.active .count {
    background: var(--color-accent);
    color: #fff;
  }

  /* ── Content ── */
  .content {
    flex: 1;
    padding: var(--space-xl);
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }
  .empty {
    color: var(--color-muted);
    text-align: center;
    padding: var(--space-3xl) var(--space-lg);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  /* ── Pending / History cards ── */
  .pw-card {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    margin-bottom: var(--space-md);
    transition: opacity 0.3s;
  }
  .pw-card .head {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }
  .pw-card .hebrew {
    font-family: var(--font-hebrew);
    font-size: 1.35rem;
    color: var(--color-ink);
    direction: rtl;
  }
  .pw-card .nikud {
    font-size: 1rem;
    color: var(--color-ink);
    direction: rtl;
  }
  .pw-card .translit {
    color: var(--color-accent);
    font-size: 0.9375rem;
  }
  .badge {
    font-size: 0.75rem;
    padding: 2px 10px;
    border-radius: var(--radius-pill);
    display: inline-block;
    font-weight: 500;
    margin-left: 8px;
  }
  .badge-red { background: #e53e3e; color: #fff; }
  .badge-green { background: #38a169; color: #fff; }
  .badge-pos {
    background: var(--color-surface-2);
    color: var(--color-muted);
  }
  .badge-approved {
    background: var(--color-green);
    color: oklch(12% 0.008 270);
  }
  .badge-rejected {
    background: var(--color-red-dim, rgba(255,80,80,0.15));
    color: var(--color-red, #ff5050);
  }
  .badge-duplicate {
    background: var(--color-yellow-dim, rgba(255,180,40,0.15));
    color: var(--color-yellow, #e6a800);
    font-size: 0.7rem;
  }
  .pw-card .translation {
    color: var(--color-ink);
    font-size: 0.9375rem;
    margin-bottom: var(--space-sm);
  }
  .pw-card .meta {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-bottom: var(--space-sm);
  }
  .examples-list {
    margin: var(--space-sm) 0;
    padding: 0;
    list-style: none;
  }
  .examples-list li {
    font-size: 0.8125rem;
    color: var(--color-muted);
    padding: 2px 0;
  }
  .examples-list li .he {
    direction: rtl;
    display: inline;
    color: var(--color-ink);
  }
  .actions {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }
  .btn-approve, .btn-reject, .btn-preview, .btn-check {
    padding: 8px 20px;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s, background 0.15s;
  }
  .btn-approve { background: var(--color-green); color: oklch(12% 0.008 270); }
  .btn-approve:hover { opacity: 0.85; }
  .btn-reject { background: var(--color-surface-2); color: var(--color-muted); border: 1px solid var(--color-rule); }
  .btn-reject:hover { background: var(--color-red); color: #fff; border-color: var(--color-red); }
  .btn-preview {
    background: var(--color-surface-2);
    color: var(--color-muted);
    padding: 8px 14px;
    font-size: 1rem;
    border: 1px solid var(--color-rule);
  }
  .btn-preview:hover { color: var(--color-accent); border-color: var(--color-accent); }
  .btn-check {
    background: var(--color-accent-dim);
    color: var(--color-accent);
    padding: 8px 14px;
    border: 1px solid var(--color-accent);
    font-size: 0.75rem;
  }
  .btn-check:hover { opacity: 0.85; }
  .btn-check:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── Check results ── */
  .check-result {
    margin-top: var(--space-sm);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    font-size: 0.8125rem;
    line-height: 1.6;
  }
  .check-result--clean { background: rgba(0,200,100,0.08); border: 1px solid rgba(0,200,100,0.25); }
  .check-result--warn { background: rgba(255,180,0,0.08); border: 1px solid rgba(255,180,0,0.25); }
  .check-result--dup { background: rgba(255,80,80,0.08); border: 1px solid rgba(255,80,80,0.25); }
  .check-result ul { margin: var(--space-xs) 0 0 var(--space-md); padding: 0; }
  .check-result li { margin: 2px 0; }

  /* ── Preview popover ── */
  .preview-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.6); z-index: 1000;
    display: flex; align-items: center; justify-content: center;
  }
  .preview-card {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    max-width: 500px; width: 90%; max-height: 80vh; overflow-y: auto;
    box-shadow: var(--card-shadow);
  }
  .preview-card .preview-close {
    float: right; background: none; border: none; color: var(--color-muted);
    font-size: 1.2rem; cursor: pointer; padding: 4px 8px;
  }

  /* ── Feedback cards ── */
  .fb-card {
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    margin-bottom: var(--space-sm);
  }
  .fb-card .fb-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }
  .fb-card .fb-word {
    font-family: var(--font-hebrew);
    font-size: 1.1rem;
    color: var(--color-ink);
    direction: rtl;
  }
  .fb-card .fb-comment {
    color: var(--color-ink);
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .fb-card .fb-meta {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin-top: var(--space-xs);
  }
  .fb-toggle {
    font-family: var(--font-body);
    font-size: 0.75rem;
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
    color: var(--color-muted);
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .fb-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ── Spinner ── */
  .spinner {
    text-align: center;
    padding: var(--space-2xl);
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  /* ── Muted (history) cards ── */
  .card-muted {
    opacity: 0.65;
    background: var(--color-surface);
    border-color: transparent;
  }
  .card-muted:hover { opacity: 0.85; }

  @media (max-width: 600px) {
    .content { padding: var(--space-md); }
    .admin-header { padding: 0 var(--space-md); }
    .tabs { padding: 0 var(--space-md); }
    .tab { padding: 10px var(--space-md); font-size: 0.8125rem; }
    .pw-card .head { gap: 6px; }
  }
</style>
</head>
<body class="admin-body">

<header class="admin-header">
  <h1>Daber Dict · Admin</h1>
  <button class="logout-btn" onclick="logout()">выйти</button>
</header>

<nav class="tabs">
  <button class="tab active" data-tab="pending">Очередь <span class="count" id="count-pending">0</span></button>
  <button class="tab" data-tab="approved">Одобрено <span class="count" id="count-approved">0</span></button>
  <button class="tab" data-tab="rejected">Отклонено <span class="count" id="count-rejected">0</span></button>
  <button class="tab" data-tab="feedback">Жалобы <span class="count" id="count-feedback">0</span></button>
  <button class="tab" data-tab="costs">Затраты</button>
</nav>

<main class="content" id="content">
  <div class="spinner">Загрузка...</div>
</main>

<script>
// ── POS Russian labels ──
const POS_RU = {
  noun: 'сущ.', verb: 'глаг.', adj: 'прил.', adv: 'нареч.',
  prep: 'предл.', conj: 'союз', pron: 'мест.', num: 'числ.',
  intj: 'межд.', particle: 'част.', pref: 'прист.', suff: 'суф.',
  art: 'арт.', det: 'опред.'
};
function posLabel(w) {
  const p = POS_RU[w.pos_slug] || w.pos_slug || '?';
  return [p, w.gender === 'm' ? 'м.р.' : w.gender === 'f' ? 'ж.р.' : ''].filter(Boolean).join(' · ');
}

// ── Auth ──
async function checkAuth() {
  try {
    const res = await fetch('/admin/api/check');
    if (!res.ok) throw new Error('no session');
  } catch(e) {
    window.location.href = '/admin/login';
  }
}

function logout() {
  document.cookie = 'daber_admin_session=; max-age=0; path=/';
  window.location.href = '/admin/login';
}

// ── Tabs ──
let activeTab = 'pending';
document.querySelectorAll('.tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeTab = btn.dataset.tab;
    loadTab();
  });
});

async function loadTab() {
  const content = document.getElementById('content');
  content.innerHTML = '<div class="spinner">Загрузка...</div>';
  try {
    if (activeTab === 'pending') await loadPending();
    else if (activeTab === 'approved') await loadApproved();
    else if (activeTab === 'rejected') await loadRejected();
    else if (activeTab === 'feedback') await loadFeedback();
    else if (activeTab === 'costs') await loadCosts();
  } catch(e) {
    if (e.message.includes('401')) { window.location.href = '/admin/login'; return; }
    content.innerHTML = '<div class="empty">Ошибка загрузки</div>';
  }
}

// ── Pending ──
async function loadPending() {
  const res = await fetch('/admin/api/pending?status=pending');
  if (res.status === 401) throw new Error('401');
  const words = await res.json();
  document.getElementById('count-pending').textContent = words.length;

  const content = document.getElementById('content');
  if (!words.length) {
    content.innerHTML = '<div class="empty">Нет слов на проверку</div>';
    return;
  }

  content.innerHTML = words.map(w => {
    const ex = w.examples ? (typeof w.examples === 'string' ? JSON.parse(w.examples) : w.examples) : [];
    const syn = w.synonyms ? (typeof w.synonyms === 'string' ? JSON.parse(w.synonyms) : w.synonyms) : [];
    const posLabelStr = posLabel(w);
    const src = w.source ? ' · ' + w.source : '';

    return `<div class="pw-card" id="pw-${w.id}">
      <div class="head">
        <span class="hebrew">${w.headword || ''}</span>
        <span class="nikud">${w.headword_nikud || ''}</span>
        <span class="translit">${w.translit || ''}</span>
        <span class="badge badge-pos">${posLabelStr}</span>
        ${w.already_exists ? '<span class="badge badge-duplicate">уже в словаре</span>' : ''}
      </div>
      <div class="translation">${w.translation_ru || (w.translation_enriched ? JSON.stringify(w.translation_enriched).replace(/[[\]"]/g,'') : '—')}</div>
      <div class="meta">${new Date(w.created_at).toLocaleString('ru')}${src}</div>
      ${ex.length ? `<ul class="examples-list">${ex.map(e => `<li><span class="he">${e.hebrew}</span> — ${e.translation}</li>`).join('')}</ul>` : ''}
      ${syn.length ? `<div class="meta">Синонимы: ${syn.map(s => s.hebrew || s).join(', ')}</div>` : ''}
      <div class="actions">
        <button class="btn-approve" onclick="approveWord(${w.id})">Одобрить</button>
        <button class="btn-reject" onclick="rejectWord(${w.id})">Отклонить</button>
        <button class="btn-check" onclick="checkWord(${w.id})" id="btn-check-${w.id}">Проверить</button>
        <button class="btn-preview" onclick="previewWord(${w.id})">👁</button>
      </div>
      <div class="check-result" id="check-${w.id}" style="display:none"></div>
    </div>`;
  }).join('');
}

async function approveWord(id) {
  const card = document.getElementById('pw-' + id);
  try {
    const res = await fetch('/admin/api/pending/' + id + '/approve', { method: 'POST' });
    const data = await res.json();
    if (data.ok) {
      card.style.opacity = '0.5';
      card.querySelector('.actions').innerHTML = data.already_existed
        ? '<span class="badge badge-approved">уже в словаре</span>'
        : '<span class="badge badge-approved">добавлено</span>';
      setTimeout(() => card.remove(), 800);
      const cnt = Math.max(0, parseInt(document.getElementById('count-pending').textContent) - 1);
      document.getElementById('count-pending').textContent = cnt;
    }
  } catch(e) { alert('Ошибка'); }
}

async function rejectWord(id) {
  const card = document.getElementById('pw-' + id);
  try {
    const res = await fetch('/admin/api/pending/' + id + '/reject?note=', { method: 'POST' });
    const data = await res.json();
    if (data.ok) {
      card.style.opacity = '0.5';
      card.querySelector('.actions').innerHTML = '<span class="badge badge-rejected">отклонено</span>';
      setTimeout(() => card.remove(), 800);
      const cnt = Math.max(0, parseInt(document.getElementById('count-pending').textContent) - 1);
      document.getElementById('count-pending').textContent = cnt;
    }
  } catch(e) { alert('Ошибка'); }
}

// ── Check word ──
async function checkWord(id) {
  const btn = document.getElementById('btn-check-' + id);
  const resultDiv = document.getElementById('check-' + id);
  btn.disabled = true;
  btn.textContent = 'Проверяю...';
  resultDiv.style.display = 'none';
  
  try {
    const res = await fetch('/admin/api/pending/' + id + '/check');
    const data = await res.json();
    
    let html = '';
    let cls = 'check-result--clean';
    
    if (data.duplicates.length > 0) {
      cls = 'check-result--dup';
      html += '<strong>⚠ Найдены совпадения:</strong><ul>';
      data.duplicates.forEach(d => {
        const sameMeaning = data.pending_translation && d.translation &&
          (d.translation.includes(data.pending_translation) || data.pending_translation.includes(d.translation));
        const icon = sameMeaning ? '🔴' : '🟢';
        const label = sameMeaning ? 'то же значение' : 'другое значение (омограф)';
        html += `<li>${icon} <b>${d.headword}</b> <em>(${d.pos})</em> — ${d.translation}
          <br><small style="color:var(--color-muted)">↳ pending: ${data.pending_translation || '—'} (${data.pending_pos}) — ${label}</small></li>`;
      });
      html += '</ul>';
    }
    
    if (data.warnings.length > 0) {
      if (!data.duplicates.length) cls = 'check-result--warn';
      html += '<strong>⚠ Предупреждения:</strong><ul>';
      data.warnings.forEach(w => { html += `<li>${w}</li>`; });
      html += '</ul>';
    }
    
    if (data.is_clean) {
      html = '✅ Всё чисто — слово можно одобрять.';
    }
    
    resultDiv.className = 'check-result ' + cls;
    resultDiv.innerHTML = html;
    resultDiv.style.display = 'block';
  } catch(e) {
    resultDiv.className = 'check-result check-result--dup';
    resultDiv.innerHTML = '❌ Ошибка проверки';
    resultDiv.style.display = 'block';
  }
  
  btn.disabled = false;
  btn.textContent = 'Проверить';
}

// ── Approved ──
async function loadApproved() {
  const res = await fetch('/admin/api/pending?status=approved');
  if (res.status === 401) throw new Error('401');
  const words = await res.json();
  document.getElementById('count-approved').textContent = words.length;

  const content = document.getElementById('content');
  if (!words.length) {
    content.innerHTML = '<div class="empty">Нет одобренных слов</div>';
    return;
  }

  content.innerHTML = words.map(w => {
    const posLabelStr = posLabel(w);
    return `<div class="pw-card card-muted">
    <div class="head">
      <span class="hebrew">${w.headword || ''}</span>
      <span class="nikud">${w.headword_nikud || ''}</span>
      <span class="translit">${w.translit || ''}</span>
      <span class="badge badge-pos">${posLabelStr}</span>
      <span class="badge badge-approved">✓</span>
    </div>
    <div class="translation">${w.translation_ru || '—'}</div>
    <div class="meta">${new Date(w.reviewed_at || w.created_at).toLocaleString('ru')}${w.source ? ' · ' + w.source : ''}</div>
  </div>`;
  }).join('');
}

// ── Rejected ──
async function loadRejected() {
  const res = await fetch('/admin/api/pending?status=rejected');
  if (res.status === 401) throw new Error('401');
  const words = await res.json();
  document.getElementById('count-rejected').textContent = words.length;

  const content = document.getElementById('content');
  if (!words.length) {
    content.innerHTML = '<div class="empty">Нет отклонённых слов</div>';
    return;
  }

  content.innerHTML = words.map(w => {
    const posLabelStr = posLabel(w);
    return `<div class="pw-card card-muted">
    <div class="head">
      <span class="hebrew">${w.headword || ''}</span>
      <span class="nikud">${w.headword_nikud || ''}</span>
      <span class="translit">${w.translit || ''}</span>
      <span class="badge badge-pos">${posLabelStr}</span>
      <span class="badge badge-rejected">✗</span>
    </div>
    <div class="translation">${w.translation_ru || '—'}</div>
    <div class="meta">${new Date(w.reviewed_at || w.created_at).toLocaleString('ru')}${w.reviewer_note ? ' · ' + w.reviewer_note : ''}${w.source ? ' · ' + w.source : ''}</div>
  </div>`;
  }).join('');
}

// ── Feedback ──
async function loadFeedback() {
  const res = await fetch('/admin/api/feedback');
  if (res.status === 401) throw new Error('401');
  const items = await res.json();
  document.getElementById('count-feedback').textContent = items.length;

  const content = document.getElementById('content');
  if (!items.length) {
    content.innerHTML = '<div class="empty">Нет жалоб</div>';
    return;
  }

  content.innerHTML = items.map(f => `<div class="fb-card">
    <div class="fb-head">
      <span>
        <span class="fb-word">${f.headword || ''}</span>
        <span style="color:var(--color-muted);font-size:0.8125rem"> · ${f.headword_nikud || ''}</span>
      </span>
      <button class="fb-toggle" onclick="toggleFeedback(${f.id})" id="fb-btn-${f.id}">${f.resolved ? 'решено' : 'не решено'}</button>
    </div>
    <div class="fb-comment">${f.comment || ''}</div>
    <div class="fb-meta">${f.field_name || ''}${f.selected_text ? ' · «' + f.selected_text + '»' : ''} · ${new Date(f.created_at).toLocaleString('ru')} · Транслит: ${f.translit || '—'}</div>
  </div>`).join('');
}

async function toggleFeedback(id) {
  const res = await fetch('/admin/api/feedback/' + id + '/toggle', { method: 'POST' });
  const data = await res.json();
  if (data.ok) {
    const btn = document.getElementById('fb-btn-' + id);
    btn.textContent = data.resolved ? 'решено' : 'не решено';
  }
}

// ── Preview ──
async function previewWord(pwId) {
  const overlay = document.createElement('div');
  overlay.className = 'preview-overlay';
  overlay.onclick = (e) => { if (e.target === overlay) overlay.remove(); };

  const card = document.createElement('div');
  card.className = 'preview-card';
  card.innerHTML = '<div class="spinner">Загрузка...</div>';
  overlay.appendChild(card);
  document.body.appendChild(overlay);

  try {
    const res = await fetch('/admin/api/pending/' + pwId + '/preview');
    if (!res.ok) throw new Error('not found');
    const data = await res.json();

    const posRu = POS_RU[data.pos] || data.pos || '';
    const genderRu = data.gender === 'm' ? 'м.р.' : data.gender === 'f' ? 'ж.р.' : '';
    const meta = [posRu, genderRu].filter(Boolean).join(' · ');
    const examples = (data.examples || []).slice(0, 3).map(e =>
      `<li><span class="he" style="direction:rtl;display:inline">${e.hebrew}</span> — ${e.translation}</li>`
    ).join('');
    const synonyms = (data.synonyms || []).slice(0, 3).map(s =>
      `<span style="display:inline-block;margin:2px 4px;padding:2px 8px;background:var(--color-surface-2);border-radius:var(--radius-sm);font-size:0.85rem"><span style="direction:rtl;display:inline">${s.hebrew}</span> ${s.translation}</span>`
    ).join('');

    card.innerHTML = `
      <button class="preview-close" onclick="this.closest('.preview-overlay').remove()">✕</button>
      <div style="font-size:1.4rem;direction:rtl;text-align:right;margin-bottom:4px">${data.headword || ''}</div>
      <div style="font-size:1.1rem;direction:rtl;text-align:right;color:var(--color-muted);margin-bottom:4px">${data.nikud || data.headword || ''}</div>
      <div style="color:var(--color-accent);font-size:1rem;margin-bottom:4px">${data.translit || ''}</div>
      <div style="font-size:0.8rem;color:var(--color-muted);margin-bottom:12px">${meta}</div>
      <div style="font-size:1rem;margin-bottom:8px">${Array.isArray(data.translations) ? data.translations.join('; ') : (data.translations || '—')}</div>
      ${examples ? '<div style="font-size:0.85rem;color:var(--color-muted);margin-top:8px">' + examples + '</div>' : ''}
      ${synonyms ? '<div style="margin-top:8px">' + synonyms + '</div>' : ''}
      ${data.notes ? '<div style="margin-top:12px;font-size:0.8rem;color:var(--color-muted);line-height:1.5;font-style:italic;border-top:1px solid var(--color-rule);padding-top:8px">' + data.notes + '</div>' : ''}
      <div style="margin-top:8px;font-size:0.75rem;color:var(--color-muted)">Источник: ${data.source || '—'} · Статус: ${data.status}</div>`;
  } catch(e) {
    card.innerHTML = `<button class="preview-close" onclick="this.closest('.preview-overlay').remove()">✕</button>
      <div style="padding:20px;text-align:center;color:var(--color-muted)">Предпросмотр недоступен</div>`;
  }
}

async function loadCosts() {
  content.innerHTML = '<div class="spinner">Загрузка...</div>';
  const [sumRes, histRes, statusRes] = await Promise.all([
    fetch('/admin/api/costs/summary'),
    fetch('/admin/api/costs?days=14'),
    fetch('/admin/api/enrichment/status'),
  ]);
  if (!sumRes.ok) throw new Error(sumRes.status);
  const summary = await sumRes.json();
  const history = await histRes.json();
  const status = await statusRes.json();
  renderCosts(summary, history, status);
}

function renderCosts(summary, history, status) {
  const { today, month, week, pricing } = summary;
  const { paused, daily_limit, today_inserted } = status;

  const pauseLabel = paused ? 'Возобновить' : 'Пауза';
  const pauseBg = paused ? 'background:#38a169;color:#fff' : 'background:#e53e3e;color:#fff';
  const statusClass = paused ? 'badge-red' : 'badge-green';
  const statusText = paused ? 'На паузе' : 'Активен';

  var usd = function(n) { return '$' + (n || 0).toFixed(6); };
  var ils = function(n) { return '\u20AA' + ((n || 0) * 3.6).toFixed(4); };
  var num = function(n) { return (n || 0).toLocaleString(); };

  // Build days table rows
  var daysRows = '';
  (history.days || []).forEach(function(d) {
    daysRows += '<tr>' +
      '<td>' + d.day + '</td>' +
      '<td>' + d.requests + '</td>' +
      '<td>' + num(d.total_tokens) + '</td>' +
      '<td style="font-family:var(--font-mono)">' + usd(d.cost_usd) + '</td>' +
      '<td>' + (d.words_inserted || 0) + '</td>' +
      '<td>' + (d.errors > 0 ? d.errors : '\u2713') + '</td>' +
      '</tr>';
  });
  if (!daysRows) daysRows = '<tr><td colspan="6" style="padding:20px;text-align:center;color:var(--color-muted)">\u041d\u0435\u0442 \u0434\u0430\u043d\u043d\u044b\u0445</td></tr>';

  var html = '<div style="display:flex;align-items:center;gap:var(--space-md);margin-bottom:var(--space-lg);flex-wrap:wrap">' +
    '<button onclick="toggleEnrichment()" style="padding:6px 16px;border:none;border-radius:var(--radius-md);font-family:var(--font-body);font-size:0.85rem;cursor:pointer;' + pauseBg + '">' + pauseLabel + '</button>' +
    ' \u0421\u0442\u0430\u0442\u0443\u0441: <span class="' + statusClass + '" style="display:inline-block;padding:2px 10px;border-radius:var(--radius-pill);font-size:0.75rem;margin-left:8px">' + statusText + '</span>' +
    '<span style="color:var(--color-muted);font-size:0.85rem;margin-left:auto">' +
    ' \u041b\u0438\u043c\u0438\u0442: <input type="number" id="dailyLimit" value="' + daily_limit + '" min="0" max="500" ' +
    'style="width:50px;padding:4px;border:1px solid var(--color-rule);border-radius:var(--radius-sm);background:var(--color-surface);color:var(--color-ink);font-family:var(--font-mono);text-align:center;font-size:0.85rem" ' +
    'onchange="setDailyLimit(this.value)">' +
    ' \u0441\u043b\u043e\u0432/\u0434\u0435\u043d\u044c \u00b7 \u0421\u0435\u0433\u043e\u0434\u043d\u044f: ' + today_inserted +
    '</span></div>';

  html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:var(--space-md);margin-bottom:var(--space-xl)">' +
    '<div class="pw-card" style="text-align:center">' +
      '<div style="font-size:0.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.5px">\u0421\u0435\u0433\u043e\u0434\u043d\u044f</div>' +
      '<div style="font-size:2rem;font-weight:700;font-family:var(--font-mono);margin:8px 0">' + usd(today.cost_usd) + '</div>' +
      '<div style="font-size:0.8rem;color:var(--color-muted)">' + ils(today.cost_usd) + ' \u00b7 ' + today.requests + ' \u0437\u0430\u043f\u0440\u043e\u0441\u043e\u0432</div>' +
    '</div>' +
    '<div class="pw-card" style="text-align:center">' +
      '<div style="font-size:0.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.5px">7 \u0434\u043d\u0435\u0439</div>' +
      '<div style="font-size:2rem;font-weight:700;font-family:var(--font-mono);margin:8px 0">' + usd(week.cost_usd) + '</div>' +
      '<div style="font-size:0.8rem;color:var(--color-muted)">' + ils(week.cost_usd) + '</div>' +
    '</div>' +
    '<div class="pw-card" style="text-align:center">' +
      '<div style="font-size:0.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.5px">\u041c\u0435\u0441\u044f\u0446</div>' +
      '<div style="font-size:2rem;font-weight:700;font-family:var(--font-mono);margin:8px 0">' + usd(month.cost_usd) + '</div>' +
      '<div style="font-size:0.8rem;color:var(--color-muted)">' + ils(month.cost_usd) + ' \u00b7 ' + month.requests + ' \u0437\u0430\u043f\u0440\u043e\u0441\u043e\u0432</div>' +
    '</div>' +
    '<div class="pw-card" style="text-align:center;border-left:3px solid var(--color-accent)">' +
      '<div style="font-size:0.75rem;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.5px">\u041c\u043e\u0434\u0435\u043b\u044c</div>' +
      '<div style="font-size:1.1rem;font-weight:600;margin:8px 0">' + pricing.model + '</div>' +
      '<div style="font-size:0.75rem;color:var(--color-muted)">in: $' + pricing.input_per_1m + '/1M \u00b7 out: $' + pricing.output_per_1m + '/1M</div>' +
    '</div>' +
  '</div>';

  html += '<h2 style="font-size:1rem;font-weight:600;margin-bottom:var(--space-md)">\u0418\u0441\u0442\u043e\u0440\u0438\u044f (14 \u0434\u043d\u0435\u0439)</h2>' +
    '<div style="overflow-x:auto">' +
    '<table style="width:100%;border-collapse:collapse;font-size:0.85rem">' +
    '<thead><tr style="text-align:left;border-bottom:2px solid var(--color-rule)">' +
    '<th style="padding:8px">\u0414\u0430\u0442\u0430</th>' +
    '<th style="padding:8px">\u0417\u0430\u043f\u0440\u043e\u0441\u043e\u0432</th>' +
    '<th style="padding:8px">\u0422\u043e\u043a\u0435\u043d\u043e\u0432</th>' +
    '<th style="padding:8px">\u0421\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c</th>' +
    '<th style="padding:8px">\u0421\u043b\u043e\u0432</th>' +
    '<th style="padding:8px">\u041e\u0448\u0438\u0431\u043e\u043a</th>' +
    '</tr></thead>' +
    '<tbody>' + daysRows + '</tbody>' +
    '</table></div>';

  var summary14 = history.summary;
  html += '<div style="margin-top:var(--space-md);padding:var(--space-md);background:var(--color-surface);border-radius:var(--radius-md);font-size:0.8rem;color:var(--color-muted)">' +
    '\u0417\u0430 14 \u0434\u043d\u0435\u0439: <strong>' + usd(summary14.total_cost_usd) + '</strong> (' + ils(summary14.total_cost_usd) + ') \u00b7 ' +
    num(summary14.total_tokens) + ' \u0442\u043e\u043a\u0435\u043d\u043e\u0432 \u00b7 ' + summary14.total_words_inserted + ' \u0441\u043b\u043e\u0432 \u0434\u043e\u0431\u0430\u0432\u043b\u0435\u043d\u043e' +
    '</div>';

  content.innerHTML = html;
}

async function toggleEnrichment() {
  const res = await fetch('/admin/api/enrichment/toggle', { method: 'POST' });
  if (!res.ok) throw new Error(res.status);
  loadCosts();  // reload tab
}

async function setDailyLimit(val) {
  const limit = parseInt(val) || 30;
  await fetch('/admin/api/enrichment/limit', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ limit }),
  });
}

// ── Init ──
checkAuth().then(() => loadTab());
</script>
</body>
</html>